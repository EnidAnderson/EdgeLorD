{
  "comments": {
    "lineComment": ";",
    "blockComment": [";|", "|;"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\((?!.*\\)).*$",
    "decreaseIndentPattern": "^\\s*\\)\\s*$"
  },
  "wordPattern": "[a-zA-Z_?!*+\\-=<>:/][a-zA-Z0-9_?!*+\\-=<>:/.'∞Σ∏Ω⊗⊕⊸□◇♯♭ʃ]*",
  "folding": {
    "markers": {
      "start": "^\\s*\\(begin\\b|^\\s*;+\\s*={3,}",
      "end": "^\\s*\\)\\s*$|^\\s*;+\\s*={3,}"
    }
  }
}
